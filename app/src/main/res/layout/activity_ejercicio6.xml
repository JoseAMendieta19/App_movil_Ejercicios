<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF4FB"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    tools:context=".Ejercicio6">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="6dp"
        android:fontFamily="sans-serif"
        android:text="6. Adivina el número"
        android:textAlignment="center"
        android:textColor="#1A3A6A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:text="Ingresa el número:"
        android:textColor="#05192E"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextNumero"
        android:layout_width="139dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="5dp"
        android:ems="10"
        android:inputType="number" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProbar"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Adivinar"
        android:textColor="#1A3A6A"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#B8D8F5"
        app:cornerRadius="20dp"
        app:elevation="0dp" />

    <TextView
        android:id="@+id/textViewPista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="15dp"
        android:textColor="#1A3A6A"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/textViewIntentos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="15dp"
        android:textColor="#7A9ABF"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reiniciar"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnvolver6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:text="Volver"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

    </LinearLayout>

</LinearLayout>