<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF4FB"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".Ejercicio8">

    <TextView
        android:id="@+id/textView7"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"
        android:text="8. Conversor de Monedas"
        android:textAlignment="center"
        android:textColor="#1A3A6A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="13dp"
        android:text="Ingresa la cantidad a convertir"
        android:textAlignment="center"
        android:textColor="#7A9ABF"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/etCantidad"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Valor"
        android:inputType="numberDecimal"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_weight="1"
            android:text="Origen: "
            android:textAlignment="center"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spOrigen"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#FFFFFF"
            android:padding="10dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:layout_weight="1"
            android:text="Detino: "
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spDestino"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#FFFFFF"
            android:padding="10dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConvertir"
        android:layout_width="150dp"
        android:layout_height="54dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="7dp"
        android:text="Convertir"
        android:textColor="#1A3A6A"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#B8D8F5"
        app:cornerRadius="20dp"
        app:elevation="0dp" />

    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="10dp"
        android:text="Resultado"
        android:textAlignment="center"
        android:textColor="#1A3A6A"
        android:textSize="18sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnvolver8"
        android:layout_width="150dp"
        android:layout_height="54dp"
        android:layout_marginTop="20dp"
        android:text="Volver"
        android:textColor="#1A3A6A"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#B8D8F5"
        app:cornerRadius="20dp"
        app:elevation="0dp" />

</LinearLayout>