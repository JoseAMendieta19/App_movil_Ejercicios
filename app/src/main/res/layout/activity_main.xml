<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF4FB">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="40dp"
        android:paddingRight="20dp"
        android:paddingBottom="30dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:text="Menú Principal"
            android:textAlignment="center"
            android:textColor="#1A3A6A"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="Selecciona un ejercicio"
            android:textAlignment="center"
            android:textColor="#7A9ABF"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio1"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="1. Área y Perímetro"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio2"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="2. Conversor de Temperatura"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio3"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="3. Tabla de Multiplicar"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio4"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="4. Calculadora de IMC"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio5"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="5. Números Primos"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio6"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="6. Adivinar Número"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio7"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="7. Cálculo de interés"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnejercicio8"
            android:layout_width="270dp"
            android:layout_height="54dp"
            android:layout_marginBottom="10dp"
            android:text="8. Conversor de Monedas"
            android:textAlignment="viewStart"
            android:textColor="#1A3A6A"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#B8D8F5"
            app:cornerRadius="20dp"
            app:elevation="0dp" />

    </LinearLayout>
</ScrollView>